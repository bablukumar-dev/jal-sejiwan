{
  "collections": {
    "users": {
      "description": "Stores user profile and role information",
      "documents": {
        "{userId}": {
          "fields": {
            "email": { "type": "string" },
            "role": { "type": "string" },
            "businessId": { "type": "string" },
            "createdAt": { "type": "timestamp" }
          },
          "allow": {
            "read": "request.auth != null && request.auth.uid == userId",
            "write": "false"
          }
        }
      }
    },
    "businesses": {
      "description": "Stores business-specific data",
      "documents": {
        "{businessId}": {
          "fields": {
            "name": { "type": "string" },
            "ownerId": { "type": "string" }
          },
          "allow": {
            "read": "request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId",
            "write": "request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner' && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId"
          },
          "collections": {
            "customers": {
              "documents": {
                "{customerId}": {
                  "allow": {
                    "read": "request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId",
                    "write": "request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId"
                  }
                }
              }
            }
          }
        }
      }
    },
    "activity_logs": {
      "description": "Audit trail for system actions",
      "documents": {
        "{activityId}": {
          "fields": {
            "activityId": { "type": "string" },
            "timestamp": { "type": "timestamp" },
            "userId": { "type": "string" },
            "userName": { "type": "string" },
            "role": { "type": "string" },
            "businessId": { "type": "string" },
            "module": { "type": "string" },
            "action": { "type": "string" },
            "status": { "type": "string" },
            "success": { "type": "boolean" }
          },
          "allow": {
            "read": "request.auth != null && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner' || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager' && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == resource.data.businessId) || (request.auth.uid == resource.data.userId))",
            "create": "request.auth != null",
            "update": "false",
            "delete": "false"
          }
        }
      }
    }
  }
}
