rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVES & HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function belongsToBusiness(businessId) {
      return isSignedIn() && getUserData().businessId == businessId;
    }

    function isOwner() {
      return isSignedIn() && getUserData().role == 'owner';
    }

    function isManager() {
      return isSignedIn() && getUserData().role == 'manager';
    }

    function isStaff() {
      return isSignedIn() && getUserData().role == 'staff';
    }

    // --- VALIDATION BLUEPRINTS ---

    function isValidTimestamp(ts) {
      return ts is timestamp || (ts is string && ts.size() <= 64);
    }

    function hasAuditFields(data) {
      return data.businessId is string 
        && data.ownerId is string 
        && data.createdBy is string
        && data.createdAt != null
        && data.updatedAt != null;
    }

    // --- ENTITY RULES ---

    // Users: Private profile and Role
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || (getUserData().businessId == existing().businessId && (isOwner() || isManager())));
      
      // Update: Users can update their own non-role fields, Owners can update roles in their business
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && incoming().role == existing().role && incoming().businessId == existing().businessId) ||
        (isOwner() && getUserData().businessId == existing().businessId && incoming().businessId == existing().businessId)
      );
      
      // Create: Handled by Admin API, but for onboarding we allow updates to completion status
      allow create: if false; // Only via Admin API or initial Auth trigger
    }

    // Businesses: Tenant profiles
    match /businesses/{businessId} {
      allow read: if belongsToBusiness(businessId);
      allow create: if isSignedIn() && isOwner() && incoming().ownerId == request.auth.uid;
      allow update: if belongsToBusiness(businessId) && isOwner() && incoming().ownerId == existing().ownerId;
    }

    // Customers: Multi-tenant collection
    match /customers/{customerId} {
      function isValidCustomer(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() < 100
          && hasAuditFields(data);
      }

      allow list: if isSignedIn() && resource.data.businessId == getUserData().businessId;
      allow get: if belongsToBusiness(existing().businessId);
      
      allow create: if isSignedIn() 
        && belongsToBusiness(incoming().businessId)
        && isValidCustomer(incoming())
        && incoming().createdBy == request.auth.uid;
        
      allow update: if isSignedIn()
        && belongsToBusiness(existing().businessId)
        && incoming().businessId == existing().businessId
        && isValidCustomer(incoming());
        
      allow delete: if belongsToBusiness(existing().businessId) && isOwner();
    }

    // Staff: Multi-tenant collection
    match /staff/{staffId} {
      allow list: if isSignedIn() && resource.data.businessId == getUserData().businessId;
      allow get: if belongsToBusiness(existing().businessId);
      
      allow create: if isOwner() && belongsToBusiness(incoming().businessId);
      allow update: if belongsToBusiness(existing().businessId) && (isOwner() || isManager());
      allow delete: if isOwner() && belongsToBusiness(existing().businessId);
    }

    // Deliveries: Multi-tenant collection
    match /deliveries/{deliveryId} {
      allow list: if isSignedIn() && resource.data.businessId == getUserData().businessId;
      allow get: if belongsToBusiness(existing().businessId);
      
      allow create: if isSignedIn() && belongsToBusiness(incoming().businessId);
      allow update: if belongsToBusiness(existing().businessId);
    }

    // Payments: Multi-tenant collection
    match /payments/{paymentId} {
      allow list: if isSignedIn() && resource.data.businessId == getUserData().businessId;
      allow get: if belongsToBusiness(existing().businessId);
      
      allow create: if isSignedIn() && belongsToBusiness(incoming().businessId);
      allow update: if belongsToBusiness(existing().businessId) && (isOwner() || isManager());
    }

    // Inventory: Business-specific document
    match /inventory/{businessId} {
      allow read: if belongsToBusiness(businessId);
      allow write: if belongsToBusiness(businessId);
    }

    // Activity Logs: Multi-tenant audit trail
    match /activity_logs/{logId} {
      allow create: if isSignedIn() && incoming().businessId == getUserData().businessId;
      allow read: if isSignedIn() && resource.data.businessId == getUserData().businessId && (isOwner() || isManager() || resource.data.userId == request.auth.uid);
      allow update, delete: if false;
    }

    // Diagnostics
    match /_diagnostics/{docId} {
      allow read: if true;
    }
  }
}
