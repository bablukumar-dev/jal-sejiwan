rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVES & HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function belongsToUser() {
      return isSignedIn() && (resource.data.userId == request.auth.uid || resource.id == request.auth.uid);
    }

    function willBelongToUser() {
      return isSignedIn() && (request.resource.data.userId == request.auth.uid || request.resource.id == request.auth.uid);
    }

    // --- ENTITY RULES ---

    // Users: Private profile
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId && incoming().role == existing().role;
      allow create: if false;
    }

    // Businesses: Tenant profiles (Isolated by userId/UID)
    match /businesses/{userId} {
      allow read: if isSignedIn() && (userId == request.auth.uid || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && (userId == request.auth.uid || incoming().userId == request.auth.uid);
      allow update: if isSignedIn() && (userId == request.auth.uid || (existing().userId == request.auth.uid && incoming().userId == request.auth.uid));
    }

    // Customers: Isolated by userId
    match /customers/{customerId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if belongsToUser();
      allow create: if willBelongToUser();
      allow update: if belongsToUser() && willBelongToUser();
      allow delete: if belongsToUser();
    }

    // Staff: Isolated by userId
    match /staff/{staffId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if belongsToUser();
      allow create: if willBelongToUser();
      allow update: if belongsToUser() && willBelongToUser();
      allow delete: if belongsToUser();
    }

    // Deliveries: Isolated by userId
    match /deliveries/{deliveryId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if belongsToUser();
      allow create: if willBelongToUser();
      allow update: if belongsToUser() && willBelongToUser();
      allow delete: if belongsToUser();
    }

    // Payments: Isolated by userId
    match /payments/{paymentId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if belongsToUser();
      allow create: if willBelongToUser();
      allow update: if belongsToUser() && willBelongToUser();
      allow delete: if belongsToUser();
    }

    // Inventory: Business-specific document (Isolated by userId/UID)
    match /inventory/{userId} {
      allow read: if isSignedIn() && (userId == request.auth.uid || resource.data.userId == request.auth.uid);
      allow write: if isSignedIn() && (userId == request.auth.uid || incoming().userId == request.auth.uid);
    }

    // Activity Logs: Isolated by userId
    match /activity_logs/{logId} {
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Diagnostics
    match /_diagnostics/{docId} {
      allow read: if true;
    }
  }
}
