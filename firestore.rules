rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      if (user == null) {
        user = get(/databases/$(database)/documents/managers/$(request.auth.uid)).data;
      }
      return user;
    }

    function isRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isBusinessOwner(businessId) {
      return isSignedIn() && getUserData().businessId == businessId;
    }

    match /activities/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    match /customers/{docId} {
      allow read, write: if request.auth != null;
    }

    match /staff_users/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Rate limiting
    match /login_attempts/{docId} {
      allow write: if true;
      allow read: if false;
    }

    // Managers
    match /managers/{docId} {
      allow read: if isSignedIn();
    }
    
    // Maintain essential existing rules
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
