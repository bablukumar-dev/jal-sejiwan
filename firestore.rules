rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Common Helpers
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function belongsToBusiness(businessId) {
      return isAuthenticated() && getUserData().businessId == businessId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 3. Rules for the users collection
    match /users/{userId} {
      // Allow user to read their own document directly
      allow read: if isAuthenticated() && request.auth.uid == userId;
      
      // Allow self-registration as 'owner' during signup
      allow create: if isAuthenticated() && request.auth.uid == userId 
        && request.resource.data.role == 'owner'
        && request.resource.data.email is string
        && request.resource.data.businessId is string;
      
      // Allow user to update their own profile, but enforce role and businessId immutability
      allow update: if isAuthenticated() && request.auth.uid == userId 
        && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)
        && (!('businessId' in request.resource.data) || request.resource.data.businessId == resource.data.businessId);
        
      allow delete: if false;
    }

    // 4. Rules for business-scoped data
    match /businesses/{businessId} {
      allow read: if belongsToBusiness(businessId);
      allow write: if belongsToBusiness(businessId) && getUserData().role == 'owner';

      match /{allSubcollections=**} {
        allow read: if belongsToBusiness(businessId);
        allow write: if belongsToBusiness(businessId);
      }
    }

    // 5. Allow reading public diagnostic documents
    match /_diagnostics/{docId} {
      allow read: if true;
    }
  }
}
