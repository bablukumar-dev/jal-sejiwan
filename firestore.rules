rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVES & HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // A user belongs to a business if their registered businessId matches the document's parent businessId.
    function isMemberOfBusiness(bId) {
      return isSignedIn() && getUserData().businessId == bId;
    }

    function getUserRole() {
      return getUserData().role;
    }

    // --- USERS ROOT COLLECTION ---
    match /users/{userId} {
      // Users can read and update their own profiles.
      allow read: if isSignedIn() && request.auth.uid == userId;
      
      // Owners and Managers can read profiles of members of the same business.
      allow read: if isSignedIn() && (
        request.auth.uid != userId && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == resource.data.businessId && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['owner', 'manager']
      );
      
      // Let any authenticated user write or merge their user doc during signup/onboarding
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
    }

    // --- BUSINESSES ROOT & SUBCOLLECTIONS ---
    match /businesses/{businessId} {
      // Owner has full access to their business doc. Managers/Staff of the same business can read.
      allow read: if isSignedIn() && isMemberOfBusiness(businessId);
      allow create: if isSignedIn(); // Allow owners to create their business during onboarding
      allow update: if isSignedIn() && isMemberOfBusiness(businessId) && getUserRole() == 'owner';
      allow delete: if false; // Completely prevent delete on businesses as requested

      // --- Customers subcollection ---
      match /customers/{customerId} {
        allow read: if isSignedIn() && isMemberOfBusiness(businessId);
        // Owner, Manager, and Staff can create/update.
        allow create, update: if isSignedIn() && isMemberOfBusiness(businessId);
        allow delete: if isSignedIn() && isMemberOfBusiness(businessId) && getUserRole() == 'owner';
      }

      // --- Payments subcollection ---
      match /payments/{paymentId} {
        allow read: if isSignedIn() && isMemberOfBusiness(businessId);
        allow create, update: if isSignedIn() && isMemberOfBusiness(businessId);
        allow delete: if isSignedIn() && isMemberOfBusiness(businessId) && getUserRole() == 'owner';
      }

      // --- Deliveries subcollection ---
      match /deliveries/{deliveryId} {
        allow read: if isSignedIn() && isMemberOfBusiness(businessId);
        allow create, update: if isSignedIn() && isMemberOfBusiness(businessId);
        allow delete: if isSignedIn() && isMemberOfBusiness(businessId) && getUserRole() == 'owner';
      }

      // --- Routes subcollection ---
      match /routes/{routeId} {
        allow read: if isSignedIn() && isMemberOfBusiness(businessId);
        allow create, update: if isSignedIn() && isMemberOfBusiness(businessId) && (getUserRole() == 'owner' || getUserRole() == 'manager');
        allow delete: if isSignedIn() && isMemberOfBusiness(businessId) && getUserRole() == 'owner';
      }

      // --- Staff subcollection ---
      match /staff/{staffId} {
        allow read: if isSignedIn() && isMemberOfBusiness(businessId);
        // Owner and Manager can manage staff. Staff can NOT manage staff ("No Staff Management" for Staff)
        allow create, update: if isSignedIn() && isMemberOfBusiness(businessId) && (getUserRole() == 'owner' || getUserRole() == 'manager');
        allow delete: if isSignedIn() && isMemberOfBusiness(businessId) && getUserRole() == 'owner';
      }

    // --- Activity Logs subcollection ---
    match /activityLogs/{logId} {
      allow read: if isSignedIn() && (isMemberOfBusiness(businessId) || getUserRole() == 'owner');
      // More permissive create for logs to ensure they are always written
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid || 
        isMemberOfBusiness(businessId)
      );
      allow update, delete: if false; // immutable logs
    }

      // --- Notifications subcollection ---
      match /notifications/{notificationId} {
        allow read: if isSignedIn() && isMemberOfBusiness(businessId);
        allow create: if isSignedIn() && isMemberOfBusiness(businessId);
        allow update: if isSignedIn() && isMemberOfBusiness(businessId);
        allow delete: if isSignedIn() && isMemberOfBusiness(businessId) && getUserRole() == 'owner';
      }

      // --- Settings subcollection (including inventory) ---
      match /settings/{settingId} {
        // Anyone in the business can read and update the inventory setting
        allow read, update: if isSignedIn() && isMemberOfBusiness(businessId) && settingId == 'inventory';
        // Only non-staff (owner, manager) can read/update other settings
        allow read, update: if isSignedIn() && isMemberOfBusiness(businessId) && settingId != 'inventory' && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'staff';
        // Only owner can create or delete settings docs
        allow create, delete: if isSignedIn() && isMemberOfBusiness(businessId) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
      }
    }
  }
}
