rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVES & HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMemberOfBusiness(businessId) {
      return isSignedIn() && getUserData().businessId == businessId;
    }

    function belongsToBusiness() {
      return isSignedIn() && (
        resource.data.businessId == getUserData().businessId || 
        resource.id == request.auth.uid || 
        resource.id == getUserData().businessId
      );
    }

    function willBelongToBusiness() {
      return isSignedIn() && (
        request.resource.data.businessId == getUserData().businessId || 
        request.resource.id == request.auth.uid ||
        request.resource.id == getUserData().businessId
      );
    }

    // --- ENTITY RULES ---

    // Users: Private profile
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isMemberOfBusiness(resource.data.businessId));
      allow update: if isSignedIn() && request.auth.uid == userId && incoming().role == existing().role;
      allow create: if false;
    }

    // Businesses: Tenant profiles (Isolated by businessId)
    match /businesses/{businessId} {
      allow read: if isSignedIn() && (businessId == getUserData().businessId || isMemberOfBusiness(businessId));
      allow create: if isSignedIn();
      allow update: if isSignedIn() && businessId == getUserData().businessId;
    }

    // Customers: Isolated by businessId
    match /customers/{customerId} {
      allow list: if isSignedIn() && isMemberOfBusiness(resource.data.businessId);
      allow get: if belongsToBusiness();
      allow create: if willBelongToBusiness();
      allow update: if belongsToBusiness() && willBelongToBusiness();
      allow delete: if belongsToBusiness();
    }

    // Staff: Isolated by businessId
    match /staff/{staffId} {
      allow list: if isSignedIn() && isMemberOfBusiness(resource.data.businessId);
      allow get: if belongsToBusiness();
      allow create: if willBelongToBusiness();
      allow update: if belongsToBusiness() && willBelongToBusiness();
      allow delete: if belongsToBusiness();
    }

    // Deliveries: Isolated by businessId
    match /deliveries/{deliveryId} {
      allow list: if isSignedIn() && isMemberOfBusiness(resource.data.businessId);
      allow get: if belongsToBusiness();
      allow create: if willBelongToBusiness();
      allow update: if belongsToBusiness() && willBelongToBusiness();
      allow delete: if belongsToBusiness();
    }

    // Payments: Isolated by businessId
    match /payments/{paymentId} {
      allow list: if isSignedIn() && isMemberOfBusiness(resource.data.businessId);
      allow get: if belongsToBusiness();
      allow create: if willBelongToBusiness();
      allow update: if belongsToBusiness() && willBelongToBusiness();
      allow delete: if belongsToBusiness();
    }

    // Inventory: Business-specific document (Isolated by businessId)
    match /inventory/{businessId} {
      allow read: if isSignedIn() && (businessId == getUserData().businessId || isMemberOfBusiness(businessId));
      allow write: if isSignedIn() && businessId == getUserData().businessId;
    }

    // Activity Logs: Isolated by businessId
    match /activity_logs/{logId} {
      allow create: if isSignedIn() && incoming().businessId == getUserData().businessId;
      allow read: if isSignedIn() && resource.data.businessId == getUserData().businessId;
      allow update, delete: if false;
    }

    // Diagnostics
    match /_diagnostics/{docId} {
      allow read: if true;
    }
  }
}
