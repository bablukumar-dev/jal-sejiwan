rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Get user document snapshot
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    function getUserData() {
      return getUserDoc().data;
    }

    function getUserBusinessId() {
      return getUserDoc().exists ? getUserDoc().data.businessId : null;
    }

    // Global deny by default
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Users collection
    // Authenticated users can read/write their own document
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // 2. Businesses collection
    // Read: authenticated users (needed for initial setup check)
    // Write: owner of the business
    match /businesses/{businessId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        resource == null || 
        resource.data.ownerId == request.auth.uid || 
        request.resource.data.ownerId == request.auth.uid
      );
    }

    // 3. Multi-tenant Collections (Scoped by businessId field)
    // We check if the document's businessId matches the user's businessId from their token
    
    function isTenant(businessId) {
      return isSignedIn() && (request.auth.token.businessId == businessId || getUserBusinessId() == businessId);
    }

    match /customers/{docId} {
      allow read, write: if isSignedIn() && (
        (resource == null && request.resource.data.businessId == (request.auth.token.businessId != null ? request.auth.token.businessId : getUserBusinessId())) ||
        (resource != null && resource.data.businessId == (request.auth.token.businessId != null ? request.auth.token.businessId : getUserBusinessId()))
      );
    }

    match /activities/{docId} {
      allow read: if isSignedIn() && (
        request.auth.token.businessId == resource.data.businessId ||
        getUserBusinessId() == resource.data.businessId
      );

      allow create: if isSignedIn() && (
        request.resource.data.businessId == request.auth.token.businessId ||
        request.resource.data.businessId == getUserBusinessId()
      );
    }

    match /staff_users/{phone} {
      allow read: if true; // Public read for PIN verification
      allow write: if isSignedIn() && (
        (resource == null && request.resource.data.businessId == (request.auth.token.businessId != null ? request.auth.token.businessId : getUserBusinessId())) ||
        (resource != null && resource.data.businessId == (request.auth.token.businessId != null ? request.auth.token.businessId : getUserBusinessId()))
      );
    }

    // 4. Workspace Scoped Subcollections
    match /workspaces/{workspaceId} {
      // workspaceId == businessId
      allow read, write: if isTenant(workspaceId);

      match /{allSubcollections=**} {
        allow read, write: if isTenant(workspaceId);
      }
    }
  }
}
